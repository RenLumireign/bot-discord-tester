# Discord Bot Token (required)
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# Groq API Key (required)
# Get from: https://console.groq.com
GROQ_KEY=your_groq_key_here

# Bot Customization (optional)
BOT_NAME=Enki
BOT_CREATOR=Your Name
BOT_PERSONALITY=You are a helpful, friendly AI assistant. You are concise, smart, and occasionally witty. Always detect the user's language and reply in the same language.

# AI Model (optional)
# Available models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
AI_MODEL=llama-3.3-70b-versatile

# Bot Settings (optional)
ACTIVE_CHANNEL=ai-chat
MEMORY_LIMIT=15
COOLDOWN_SECONDS=3

# Database Path (optional)
DB_PATH=chatbot.db
